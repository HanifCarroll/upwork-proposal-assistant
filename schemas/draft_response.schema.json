{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "draft_text",
    "draft_type",
    "subject_line",
    "question_answers",
    "selected_angle",
    "role_classification",
    "application_strategy",
    "selected_projects",
    "rejected_projects",
    "decisions",
    "claims",
    "warnings"
  ],
  "properties": {
    "draft_text": { "type": "string" },
    "draft_type": {
      "type": "string",
      "enum": ["upwork_proposal", "cover_letter", "short_application_message", "question_answers"]
    },
    "subject_line": { "type": "string" },
    "question_answers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "answer", "caused_by"],
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "caused_by": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "selected_angle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "promise", "caused_by"],
      "properties": {
        "key": { "type": "string" },
        "label": { "type": "string" },
        "promise": { "type": "string" },
        "caused_by": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "role_classification": { "type": "string" },
    "application_strategy": { "type": "string" },
    "selected_projects": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rejected_projects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "reason", "caused_by"],
        "properties": {
          "slug": { "type": "string" },
          "reason": { "type": "string" },
          "caused_by": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["audit_id", "decision", "caused_by", "rationale"],
        "properties": {
          "audit_id": { "type": "string" },
          "decision": { "type": "string" },
          "caused_by": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rationale": { "type": "string" }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "caused_by"],
        "properties": {
          "text": { "type": "string" },
          "caused_by": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
