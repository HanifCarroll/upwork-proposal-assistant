#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

uv --no-config run mypy src tests
uv --no-config run pytest

node --check extension/background.js
node --check extension/popup.js
node --check extension/sidepanel.js
node --check extension/content_script.js
node --check extension/application_logger.js
node --check extension/dice_wizard_assistant.js
node --check extension/options.js

python3 -m json.tool extension/manifest.json >/dev/null
python3 -m json.tool schemas/draft_response.schema.json >/dev/null

git diff --check
