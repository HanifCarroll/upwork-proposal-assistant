{
  "manifest_version": 3,
  "name": "Job Application Draft Assistant",
  "version": "0.1.0",
  "description": "Extract job context and draft auditable applications through a local Python/Codex backend.",
  "action": {
    "default_title": "Draft application"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": [
    "https://www.upwork.com/*",
    "https://*.upwork.com/*",
    "https://www.dice.com/*",
    "https://*.dice.com/*",
    "https://www.indeed.com/*",
    "https://*.indeed.com/*",
    "https://www.ziprecruiter.com/*",
    "https://*.ziprecruiter.com/*",
    "https://www.roberthalf.com/*",
    "https://*.roberthalf.com/*",
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.upwork.com/*",
        "https://*.upwork.com/*",
        "https://www.dice.com/*",
        "https://*.dice.com/*",
        "https://www.indeed.com/*",
        "https://*.indeed.com/*",
        "https://www.ziprecruiter.com/*",
        "https://*.ziprecruiter.com/*",
        "https://www.roberthalf.com/*",
        "https://*.roberthalf.com/*",
        "https://www.linkedin.com/*",
        "https://*.linkedin.com/*"
      ],
      "js": [
        "extractors/common.js",
        "platforms/dice_opportunity.js",
        "platforms/indeed_opportunity.js",
        "platforms/linkedin_opportunity.js",
        "extractors/upwork.js",
        "extractors/dice.js",
        "extractors/indeed.js",
        "extractors/ziprecruiter.js",
        "extractors/roberthalf.js",
        "extractors/linkedin.js",
        "ui/cover_letter_runs.js",
        "content_script.js",
        "application/ledger_badge.js",
        "application_logger.js",
        "dice_wizard_assistant.js",
        "indeed_smartapply_assistant.js",
        "linkedin_easy_apply_assistant.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
