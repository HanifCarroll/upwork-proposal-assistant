{
  "manifest_version": 3,
  "name": "Job Application Draft Assistant",
  "version": "0.1.0",
  "description": "Extract job context and draft auditable applications through a local Python/Codex backend.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Draft application"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": [
    "https://www.upwork.com/*",
    "https://*.upwork.com/*",
    "https://www.dice.com/*",
    "https://*.dice.com/*",
    "https://www.indeed.com/*",
    "https://*.indeed.com/*",
    "https://www.ziprecruiter.com/*",
    "https://*.ziprecruiter.com/*",
    "https://www.roberthalf.com/*",
    "https://*.roberthalf.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.upwork.com/*",
        "https://*.upwork.com/*",
        "https://www.dice.com/*",
        "https://*.dice.com/*",
        "https://www.indeed.com/*",
        "https://*.indeed.com/*",
        "https://www.ziprecruiter.com/*",
        "https://*.ziprecruiter.com/*",
        "https://www.roberthalf.com/*",
        "https://*.roberthalf.com/*"
      ],
      "js": ["content_script.js", "application_logger.js", "dice_wizard_assistant.js"],
      "run_at": "document_idle"
    }
  ]
}
