# Optional. Defaults to examples/portfolio.
UPWORK_PROPOSAL_PORTFOLIO_ROOT=examples/portfolio

# Optional. Generated context cache. Do not commit real generated context.
UPWORK_PROPOSAL_CONTEXT_DIR=data/context

# Optional. Runtime data location for SQLite drafts and Codex run workspaces.
UPWORK_PROPOSAL_RUNTIME_DIR=.runtime
UPWORK_PROPOSAL_DB_PATH=.runtime/drafts.db
UPWORK_PROPOSAL_CODEX_RUNS_DIR=.runtime/codex-runs

# Optional. Defaults to `codex` on PATH.
UPWORK_PROPOSAL_CODEX_BINARY=codex
UPWORK_PROPOSAL_CODEX_MODEL=gpt-5.5
UPWORK_PROPOSAL_CODEX_REASONING_EFFORT=xhigh
UPWORK_PROPOSAL_CODEX_TIMEOUT_SECONDS=180

# Optional. Used to expose the humanizer skill to `codex exec`.
UPWORK_PROPOSAL_HUMANIZER_SKILL=~/.codex/skills/humanizer
